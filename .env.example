ADMIN_PASSWORD=changeme123

# Public key of the WireGuard server (from: wg show wg0 public-key)
SERVER_PUBLIC_KEY=

# Server IP and port. Port is used as fallback only — in production the
# actual listen port is read from `wg show wg0 listen-port` at config
# generation time, so this must match the real server address.
SERVER_ENDPOINT=your-server-ip:51820

# WireGuard interface name on the server
WG_INTERFACE=wg0

# DNS servers written into client configs (comma-separated)
DNS=1.1.1.1,1.0.0.1
